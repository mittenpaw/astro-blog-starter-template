---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead
			title="アクセス・お問い合わせ | 真照寺"
			description="真宗大谷派 真照寺へのアクセス方法とお問い合わせ先をご案内します。"
		/>
		<style>
			main {
				max-width: 680px;
				margin: 0 auto;
				padding: 4em 1.5em 6em;
			}
			.page-header {
				padding-bottom: 2.5em;
				border-bottom: 1px solid rgb(var(--gray-light));
				margin-bottom: 3em;
			}
			.page-title {
				font-size: 1.5em;
				font-weight: 400;
				letter-spacing: 0.2em;
				color: rgb(var(--black));
				margin: 0 0 0.5em;
			}
			.page-subtitle {
				font-size: 0.85em;
				color: rgb(var(--gray));
				letter-spacing: 0.08em;
				margin: 0;
			}

			.map-placeholder {
				width: 100%;
				aspect-ratio: 16 / 9;
				background: rgb(var(--gray-light));
				border-radius: 4px;
				display: flex;
				align-items: center;
				justify-content: center;
				margin-bottom: 3em;
				color: rgb(var(--gray));
				font-size: 0.82em;
				letter-spacing: 0.12em;
			}

			.section-label {
				font-size: 0.72em;
				letter-spacing: 0.25em;
				text-transform: uppercase;
				color: rgb(var(--gray));
				margin: 0 0 1.5em;
				display: flex;
				align-items: center;
				gap: 1em;
			}
			.section-label::after {
				content: '';
				flex: 1;
				height: 1px;
				background: rgb(var(--gray-light));
			}

			.info-block {
				margin-bottom: 3em;
			}
			.info-table {
				width: 100%;
				border-collapse: collapse;
				font-size: 0.9em;
			}
			.info-table tr {
				border-bottom: 1px solid rgb(var(--gray-light));
			}
			.info-table td {
				padding: 1.1em 0;
				vertical-align: top;
				line-height: 1.9;
			}
			.info-table td:first-child {
				width: 6em;
				color: rgb(var(--gray));
				font-size: 0.85em;
				letter-spacing: 0.05em;
			}
			.info-table a {
				color: var(--accent);
				text-decoration: none;
				border-bottom: 1px solid transparent;
				transition: border-color 0.15s;
			}
			.info-table a:hover {
				border-bottom-color: var(--accent);
			}

			.contact-note {
				padding: 2em;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 2px;
				background: white;
				font-size: 0.88em;
				color: rgb(var(--gray));
				line-height: 1.9;
			}
			.contact-note a {
				color: var(--accent);
				text-decoration: none;
				border-bottom: 1px solid var(--accent);
			}

			@media (max-width: 720px) {
				main { padding: 2em 1.2em 4em; }
				.info-table td:first-child { width: 5em; }
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="page-header">
				<h1 class="page-title">アクセス</h1>
				<p class="page-subtitle">真宗大谷派 真照寺</p>
			</div>

			<div class="map-placeholder">地図（準備中）</div>

			<div class="info-block">
				<p class="section-label">所在地・連絡先</p>
				<table class="info-table">
					<tr>
						<td>住所</td>
						<td>〒XXX-XXXX<br>〇〇県〇〇市〇〇町X-X</td>
					</tr>
					<tr>
						<td>電話</td>
						<td>0XX-XXX-XXXX</td>
					</tr>
					<tr>
						<td>受付時間</td>
						<td>午前9時〜午後5時（月〜土）</td>
					</tr>
					<tr>
						<td>メール</td>
						<td><a href="mailto:yoshio_kawamoto@hotmail.com">yoshio_kawamoto@hotmail.com</a></td>
					</tr>
				</table>
			</div>

			<div class="info-block">
				<p class="section-label">交通案内</p>
				<table class="info-table">
					<tr>
						<td>電車</td>
						<td>○○線「○○駅」下車、徒歩○分</td>
					</tr>
					<tr>
						<td>バス</td>
						<td>○○バス「○○停留所」下車、徒歩○分</td>
					</tr>
					<tr>
						<td>お車</td>
						<td>〇〇インター出口より○分<br>境内に駐車場あり</td>
					</tr>
				</table>
			</div>

			<div class="contact-note">
				法事・葬儀のご相談、ご法話のお申し込み、その他お問い合わせは、お電話またはメールにてお気軽にどうぞ。<br><br>
				メール: <a href="mailto:yoshio_kawamoto@hotmail.com">yoshio_kawamoto@hotmail.com</a>
			</div>
		</main>
		<Footer />
	</body>
</html>
