---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead
			title="アクセス・お問い合わせ | 真照寺"
			description="真宗大谷派 真照寺へのアクセス方法とお問い合わせ先をご案内します。"
		/>
		<style>
			main {
				max-width: 680px;
				margin: 0 auto;
				padding: 4em 1.5em 6em;
			}
			.page-header {
				padding-bottom: 2.5em;
				border-bottom: 1px solid rgb(var(--gray-light));
				margin-bottom: 3em;
			}
			.page-title {
				font-size: 1.5em;
				font-weight: 400;
				letter-spacing: 0.2em;
				color: rgb(var(--black));
				margin: 0 0 0.5em;
			}
			.page-subtitle {
				font-size: 0.85em;
				color: rgb(var(--gray));
				letter-spacing: 0.08em;
				margin: 0;
			}

			.map-wrap {
				width: 100%;
				margin-bottom: 3em;
				border-radius: 4px;
				overflow: hidden;
				border: 1px solid rgb(var(--gray-light));
			}
			.map-wrap iframe {
				display: block;
				width: 100%;
				height: 380px;
				border: 0;
			}

			.section-label {
				font-size: 0.72em;
				letter-spacing: 0.25em;
				text-transform: uppercase;
				color: rgb(var(--gray));
				margin: 0 0 1.5em;
				display: flex;
				align-items: center;
				gap: 1em;
			}
			.section-label::after {
				content: '';
				flex: 1;
				height: 1px;
				background: rgb(var(--gray-light));
			}

			.info-block {
				margin-bottom: 3em;
			}
			.info-table {
				width: 100%;
				border-collapse: collapse;
				font-size: 0.9em;
			}
			.info-table tr {
				border-bottom: 1px solid rgb(var(--gray-light));
			}
			.info-table td {
				padding: 1.1em 0;
				vertical-align: top;
				line-height: 1.9;
			}
			.info-table td:first-child {
				width: 6em;
				color: rgb(var(--gray));
				font-size: 0.85em;
				letter-spacing: 0.05em;
			}
			.info-table a {
				color: var(--accent);
				text-decoration: none;
				border-bottom: 1px solid transparent;
				transition: border-color 0.15s;
			}
			.info-table a:hover {
				border-bottom-color: var(--accent);
			}

			.contact-note {
				padding: 2em;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 2px;
				background: white;
				font-size: 0.88em;
				color: rgb(var(--gray));
				line-height: 1.9;
			}
			.contact-note a {
				color: var(--accent);
				text-decoration: none;
				border-bottom: 1px solid var(--accent);
			}

			@media (max-width: 720px) {
				main { padding: 2em 1.2em 4em; }
				.info-table td:first-child { width: 5em; }
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="page-header">
				<h1 class="page-title">アクセス</h1>
				<p class="page-subtitle">真宗大谷派 真照寺</p>
			</div>

			<div class="map-wrap">
				<iframe
					src="https://maps.google.com/maps?q=%E7%A5%9E%E5%A5%88%E5%B7%9D%E7%9C%8C%E6%A8%AA%E6%B5%9C%E5%B8%82%E9%83%BD%E7%AD%91%E5%8C%BA%E6%8A%98%E6%9C%AC%E7%94%BA1604&output=embed&hl=ja&z=16"
					loading="lazy"
					referrerpolicy="no-referrer-when-downgrade"
					title="真照寺 地図"
				></iframe>
			</div>

			<div class="info-block">
				<p class="section-label">所在地・連絡先</p>
				<table class="info-table">
					<tr>
						<td>住所</td>
						<td>神奈川県横浜市都筑区折本町1604</td>
					</tr>
					<tr>
						<td>電話</td>
						<td>0XX-XXX-XXXX</td>
					</tr>
					<tr>
						<td>受付時間</td>
						<td>午前9時〜午後5時（月〜土）</td>
					</tr>
					<tr>
						<td>メール</td>
						<td><a href="mailto:yoshio_kawamoto@hotmail.com">yoshio_kawamoto@hotmail.com</a></td>
					</tr>
				</table>
			</div>

			<div class="info-block">
				<p class="section-label">交通案内</p>
				<table class="info-table">
					<tr>
						<td>電車</td>
						<td>○○線「○○駅」下車、徒歩○分</td>
					</tr>
					<tr>
						<td>バス</td>
						<td>○○バス「○○停留所」下車、徒歩○分</td>
					</tr>
					<tr>
						<td>お車</td>
						<td>〇〇インター出口より○分<br>境内に駐車場あり</td>
					</tr>
				</table>
			</div>

			<div class="contact-note">
				法事・葬儀のご相談、ご法話のお申し込み、その他お問い合わせは、お電話またはメールにてお気軽にどうぞ。<br><br>
				メール: <a href="mailto:yoshio_kawamoto@hotmail.com">yoshio_kawamoto@hotmail.com</a>
			</div>
		</main>
		<Footer />
	</body>
</html>
