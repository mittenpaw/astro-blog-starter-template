---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead
			title="お知らせ | 真照寺"
			description="真照寺からのお知らせ、住職のブログ記事をご覧いただけます。"
		/>
		<style>
			main {
				max-width: 680px;
				margin: 0 auto;
				padding: 4em 1.5em 6em;
			}
			.page-header {
				padding-bottom: 2.5em;
				border-bottom: 1px solid rgb(var(--gray-light));
				margin-bottom: 3em;
			}
			.page-title {
				font-size: 1.5em;
				font-weight: 400;
				letter-spacing: 0.2em;
				color: rgb(var(--black));
				margin: 0 0 0.5em;
			}
			.page-subtitle {
				font-size: 0.85em;
				color: rgb(var(--gray));
				letter-spacing: 0.08em;
				margin: 0;
			}

			.posts {
				list-style: none;
				margin: 0;
				padding: 0;
			}
			.posts li {
				border-bottom: 1px solid rgb(var(--gray-light));
			}
			.posts li a {
				display: block;
				padding: 1.6em 0;
				text-decoration: none;
				color: inherit;
				transition: all 0.15s;
			}
			.posts li a:hover .post-title {
				color: var(--accent);
			}
			.post-title {
				font-size: 1.05em;
				font-weight: 700;
				color: rgb(var(--black));
				margin: 0 0 0.4em;
				line-height: 1.5;
				letter-spacing: 0.02em;
				transition: color 0.15s;
			}
			.post-meta {
				font-size: 0.78em;
				color: rgb(var(--gray));
				letter-spacing: 0.05em;
				margin-bottom: 0.4em;
			}
			.post-desc {
				margin: 0;
				font-size: 0.88em;
				color: rgb(var(--gray));
				line-height: 1.7;
			}

			@media (max-width: 720px) {
				main { padding: 2em 1.2em 4em; }
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="page-header">
				<h1 class="page-title">お知らせ</h1>
				<p class="page-subtitle">住職のブログ・寺院からのお知らせ</p>
			</div>

			<ul class="posts">
				{
					posts.map((post) => (
						<li>
							<a href={`${import.meta.env.BASE_URL}/blog/${post.id}/`}>
								<p class="post-title">{post.data.title}</p>
								<div class="post-meta">
									<FormattedDate date={post.data.pubDate} />
								</div>
								{post.data.description && (
									<p class="post-desc">{post.data.description}</p>
								)}
							</a>
						</li>
					))
				}
			</ul>
		</main>
		<Footer />
	</body>
</html>
