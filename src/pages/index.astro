---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION, AUTHOR_NAME } from '../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';

const recentPosts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.hero {
				padding: 4em 0 3em;
				text-align: center;
				border-bottom: 1px solid rgb(var(--gray-light));
				margin-bottom: 3em;
			}
			.hero h1 {
				font-size: 2.5em;
				margin-bottom: 0.4em;
			}
			.hero p {
				font-size: 1.1em;
				color: rgb(var(--gray));
				margin: 0;
			}
			.hero .tagline {
				display: inline-block;
				margin-top: 1em;
				padding: 0.4em 1em;
				background: rgba(var(--accent), 0.08);
				color: var(--accent);
				border-radius: 999px;
				font-size: 0.9em;
			}
			.section-title {
				font-size: 1.3em;
				color: rgb(var(--gray-dark));
				border-left: 4px solid var(--accent);
				padding-left: 0.7em;
				margin-bottom: 1.5em;
			}
			.recent-posts {
				list-style: none;
				margin: 0 0 3em;
				padding: 0;
				display: flex;
				flex-direction: column;
				gap: 1.2em;
			}
			.recent-posts li a {
				display: flex;
				gap: 1em;
				text-decoration: none;
				color: inherit;
				padding: 1em;
				border-radius: 8px;
				transition: background 0.2s;
			}
			.recent-posts li a:hover {
				background: rgb(var(--gray-light), 0.4);
			}
			.recent-posts .post-info {
				flex: 1;
			}
			.recent-posts .post-title {
				font-size: 1.1em;
				font-weight: 700;
				color: rgb(var(--black));
				margin: 0 0 0.2em;
				line-height: 1.3;
			}
			.recent-posts .post-date {
				font-size: 0.85em;
				color: rgb(var(--gray));
			}
			.recent-posts img {
				width: 120px;
				height: 60px;
				object-fit: cover;
				border-radius: 6px;
				flex-shrink: 0;
			}
			.all-posts-link {
				text-align: right;
				margin-bottom: 3em;
			}
			.all-posts-link a {
				font-size: 0.95em;
			}
			.about-section {
				background: rgb(var(--gray-light), 0.3);
				border-radius: 12px;
				padding: 2em;
				margin-bottom: 3em;
			}
			.about-section p {
				margin: 0.5em 0 0;
				color: rgb(var(--gray-dark));
			}
			@media (max-width: 720px) {
				.hero h1 { font-size: 1.8em; }
				.recent-posts img { display: none; }
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="hero">
				<h1>こんにちは、{AUTHOR_NAME}です。</h1>
				<p>技術・日常・思考を自由に綴るブログです。</p>
				<span class="tagline">エンジニア / ライター / 探求者</span>
			</div>

			<h2 class="section-title">最近の記事</h2>
			<ul class="recent-posts">
				{
					recentPosts.map((post) => (
						<li>
							<a href={`/blog/${post.id}/`}>
								{post.data.heroImage && (
									<img src={post.data.heroImage} alt={post.data.title} />
								)}
								<div class="post-info">
									<p class="post-title">{post.data.title}</p>
									<p class="post-date">
										<FormattedDate date={post.data.pubDate} />
									</p>
								</div>
							</a>
						</li>
					))
				}
			</ul>
			<div class="all-posts-link">
				<a href="/blog">すべての記事を見る &rarr;</a>
			</div>

			<div class="about-section">
				<h2 class="section-title" style="border-left: none; padding-left: 0;">このサイトについて</h2>
				<p>
					このブログは、日々の学びや気づき、技術的なメモ、そして雑多な思考を記録する場所です。
					完璧な記事より、素直なアウトプットを大切にしています。
				</p>
				<p>
					<a href="/about">プロフィールはこちら &rarr;</a>
				</p>
			</div>
		</main>
		<Footer />
	</body>
</html>
