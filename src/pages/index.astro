---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';

const recentPosts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 5);
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				max-width: 680px;
				margin: 0 auto;
				padding: 4em 1.5em 6em;
			}

			/* ── 冒頭の一行 ── */
			.opening {
				text-align: center;
				padding: 5em 0 4em;
				border-bottom: 1px solid rgb(var(--gray-light));
				margin-bottom: 4em;
			}
			.opening .phrase {
				font-size: 1.5em;
				font-weight: 400;
				letter-spacing: 0.15em;
				color: rgb(var(--black));
				line-height: 1.6;
				margin: 0 0 1.5em;
			}
			.opening .phrase em {
				font-style: normal;
				color: var(--accent);
			}
			.opening .byline {
				font-size: 0.85em;
				color: rgb(var(--gray));
				letter-spacing: 0.1em;
				line-height: 2;
				margin: 0;
			}
			.opening .byline a {
				color: rgb(var(--gray));
				text-decoration: none;
				border-bottom: 1px solid rgb(var(--gray-light));
			}
			.opening .byline a:hover {
				color: var(--accent);
				border-bottom-color: var(--accent);
			}

			/* ── セクション見出し ── */
			.section-label {
				font-size: 0.72em;
				letter-spacing: 0.25em;
				text-transform: uppercase;
				color: rgb(var(--gray));
				margin: 0 0 2em;
				display: flex;
				align-items: center;
				gap: 1em;
			}
			.section-label::after {
				content: '';
				flex: 1;
				height: 1px;
				background: rgb(var(--gray-light));
			}

			/* ── 記事リスト ── */
			.posts {
				list-style: none;
				margin: 0 0 5em;
				padding: 0;
			}
			.posts li {
				border-bottom: 1px solid rgb(var(--gray-light));
			}
			.posts li a {
				display: block;
				padding: 1.6em 0;
				text-decoration: none;
				color: inherit;
				transition: all 0.15s;
			}
			.posts li a:hover .post-title {
				color: var(--accent);
			}
			.post-title {
				font-size: 1.05em;
				font-weight: 700;
				color: rgb(var(--black));
				margin: 0 0 0.4em;
				line-height: 1.5;
				letter-spacing: 0.02em;
				transition: color 0.15s;
			}
			.post-meta {
				display: flex;
				align-items: center;
				gap: 0.8em;
				font-size: 0.78em;
				color: rgb(var(--gray));
				letter-spacing: 0.05em;
			}
			.post-desc {
				margin: 0.5em 0 0;
				font-size: 0.88em;
				color: rgb(var(--gray));
				line-height: 1.7;
			}

			.more-link {
				text-align: right;
				margin-bottom: 5em;
			}
			.more-link a {
				font-size: 0.85em;
				letter-spacing: 0.08em;
				color: var(--accent);
				text-decoration: none;
				border-bottom: 1px solid var(--accent);
				padding-bottom: 1px;
			}

			/* ── テーマ一覧 ── */
			.themes {
				display: flex;
				flex-wrap: wrap;
				gap: 0.8em;
				margin: 0 0 2em;
			}
			.theme-tag {
				font-size: 0.82em;
				padding: 0.4em 1em;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 2px;
				color: rgb(var(--gray));
				letter-spacing: 0.05em;
				background: white;
			}

			@media (max-width: 720px) {
				.opening { padding: 3em 0 2.5em; }
				.opening .phrase { font-size: 1.2em; }
				main { padding: 2em 1.2em 4em; }
			}
		</style>
	</head>
	<body>
		<Header />
		<main>

			<div class="opening">
				<p class="phrase">
					すべては<em>空</em>である——<br>だから、つながる。
				</p>
				<p class="byline">
					真宗大谷派 僧侶・リキンダによる覚書。<br>
					龍樹の哲学と人工知能について、思ったことを書き連ねています。<br>
					<a href={`${import.meta.env.BASE_URL}/about`}>プロフィール</a>
				</p>
			</div>

			<p class="section-label">最近の思索</p>
			<ul class="posts">
				{
					recentPosts.map((post) => (
						<li>
							<a href={`${import.meta.env.BASE_URL}/blog/${post.id}/`}>
								<p class="post-title">{post.data.title}</p>
								<div class="post-meta">
									<FormattedDate date={post.data.pubDate} />
								</div>
								{post.data.description && (
									<p class="post-desc">{post.data.description}</p>
								)}
							</a>
						</li>
					))
				}
			</ul>
			<div class="more-link">
				<a href={`${import.meta.env.BASE_URL}/blog`}>すべての記事 →</a>
			</div>

			<p class="section-label">主なテーマ</p>
			<div class="themes">
				<span class="theme-tag">龍樹・中観思想</span>
				<span class="theme-tag">空（śūnyatā）</span>
				<span class="theme-tag">真宗大谷派</span>
				<span class="theme-tag">人工知能（AI）</span>
				<span class="theme-tag">仏教と哲学</span>
				<span class="theme-tag">親鸞</span>
			</div>

		</main>
		<Footer />
	</body>
</html>
