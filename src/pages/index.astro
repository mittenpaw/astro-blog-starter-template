---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';

const recentPosts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);

const upcomingEvents = [
	{ month: "11月", name: "報恩講", date: "11月下旬" },
	{ month: "1月", name: "修正会", date: "1月1日" },
	{ month: "3月", name: "春季彼岸会", date: "春分の日前後" },
];
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				max-width: 680px;
				margin: 0 auto;
				padding: 0 1.5em 6em;
			}

			/* ── ヒーロー ── */
			.hero {
				text-align: center;
				padding: 5em 0 4.5em;
				border-bottom: 1px solid rgb(var(--gray-light));
				margin-bottom: 4em;
			}
			.hero .denomination {
				font-size: 0.78em;
				letter-spacing: 0.3em;
				color: rgb(var(--gray));
				margin: 0 0 0.6em;
			}
			.hero .temple-name {
				font-size: 2.4em;
				font-weight: 400;
				letter-spacing: 0.2em;
				color: rgb(var(--black));
				margin: 0 0 0.5em;
				line-height: 1.2;
			}
			.hero .tagline {
				font-size: 0.95em;
				letter-spacing: 0.18em;
				color: rgb(var(--gray));
				margin: 0 0 2em;
			}
			.hero .address {
				font-size: 0.8em;
				color: rgb(var(--gray));
				letter-spacing: 0.08em;
				margin: 0 0 2em;
				line-height: 2;
			}
			.hero-links {
				display: flex;
				justify-content: center;
				gap: 1em;
			}
			.hero-links a {
				font-size: 0.82em;
				letter-spacing: 0.1em;
				padding: 0.6em 1.6em;
				border: 1px solid rgb(var(--gray-light));
				color: rgb(var(--gray-dark));
				text-decoration: none;
				border-radius: 2px;
				transition: all 0.15s;
			}
			.hero-links a:hover {
				border-color: var(--accent);
				color: var(--accent);
			}
			.hero-links a.primary {
				background: var(--accent);
				border-color: var(--accent);
				color: white;
			}
			.hero-links a.primary:hover {
				background: var(--accent-dark);
				border-color: var(--accent-dark);
				color: white;
			}

			/* ── セクション見出し ── */
			.section-label {
				font-size: 0.72em;
				letter-spacing: 0.25em;
				text-transform: uppercase;
				color: rgb(var(--gray));
				margin: 0 0 2em;
				display: flex;
				align-items: center;
				gap: 1em;
			}
			.section-label::after {
				content: '';
				flex: 1;
				height: 1px;
				background: rgb(var(--gray-light));
			}

			/* ── お知らせリスト ── */
			.posts {
				list-style: none;
				margin: 0 0 1.5em;
				padding: 0;
			}
			.posts li {
				border-bottom: 1px solid rgb(var(--gray-light));
			}
			.posts li a {
				display: block;
				padding: 1.4em 0;
				text-decoration: none;
				color: inherit;
				transition: all 0.15s;
			}
			.posts li a:hover .post-title {
				color: var(--accent);
			}
			.post-title {
				font-size: 1em;
				font-weight: 700;
				color: rgb(var(--black));
				margin: 0 0 0.35em;
				line-height: 1.5;
				letter-spacing: 0.02em;
				transition: color 0.15s;
			}
			.post-meta {
				font-size: 0.78em;
				color: rgb(var(--gray));
				letter-spacing: 0.05em;
			}
			.post-desc {
				margin: 0.4em 0 0;
				font-size: 0.87em;
				color: rgb(var(--gray));
				line-height: 1.7;
			}

			.more-link {
				text-align: right;
				margin-bottom: 4.5em;
			}
			.more-link a {
				font-size: 0.82em;
				letter-spacing: 0.08em;
				color: var(--accent);
				text-decoration: none;
				border-bottom: 1px solid var(--accent);
				padding-bottom: 1px;
			}

			/* ── 年間行事プレビュー ── */
			.events-list {
				list-style: none;
				padding: 0;
				margin: 0 0 1.5em;
			}
			.events-list li {
				display: flex;
				align-items: baseline;
				gap: 1.2em;
				padding: 1em 0;
				border-bottom: 1px solid rgb(var(--gray-light));
				font-size: 0.9em;
			}
			.event-month {
				font-size: 0.78em;
				color: var(--accent);
				letter-spacing: 0.05em;
				min-width: 2.5em;
			}
			.event-name {
				color: rgb(var(--black));
				font-weight: 700;
				letter-spacing: 0.05em;
				flex: 1;
			}
			.event-date {
				font-size: 0.82em;
				color: rgb(var(--gray));
				letter-spacing: 0.03em;
			}

			@media (max-width: 720px) {
				.hero { padding: 3.5em 0 3em; }
				.hero .temple-name { font-size: 1.8em; }
				main { padding: 0 1.2em 4em; }
			}
		</style>
	</head>
	<body>
		<Header />
		<main>

			<div class="hero">
				<p class="denomination">真宗大谷派</p>
				<h1 class="temple-name">真照寺</h1>
				<p class="tagline">念仏の道を、ともに歩む。</p>
				<p class="address">
					神奈川県横浜市都筑区折本町1604<br>
					TEL: 0XX-XXX-XXXX
				</p>
				<div class="hero-links">
					<a class="primary" href={`${import.meta.env.BASE_URL}/access`}>アクセス</a>
					<a href={`${import.meta.env.BASE_URL}/events`}>年間行事</a>
				</div>
			</div>

			<p class="section-label">最新のお知らせ</p>
			<ul class="posts">
				{
					recentPosts.map((post) => (
						<li>
							<a href={`${import.meta.env.BASE_URL}/blog/${post.id}/`}>
								<p class="post-title">{post.data.title}</p>
								<div class="post-meta">
									<FormattedDate date={post.data.pubDate} />
								</div>
								{post.data.description && (
									<p class="post-desc">{post.data.description}</p>
								)}
							</a>
						</li>
					))
				}
			</ul>
			<div class="more-link">
				<a href={`${import.meta.env.BASE_URL}/blog`}>すべてのお知らせ →</a>
			</div>

			<p class="section-label">年間行事</p>
			<ul class="events-list">
				{
					upcomingEvents.map((e) => (
						<li>
							<span class="event-month">{e.month}</span>
							<span class="event-name">{e.name}</span>
							<span class="event-date">{e.date}</span>
						</li>
					))
				}
			</ul>
			<div class="more-link">
				<a href={`${import.meta.env.BASE_URL}/events`}>すべての行事を見る →</a>
			</div>

		</main>
		<Footer />
	</body>
</html>
